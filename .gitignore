# Python caches and virtual environments
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
ENV/

# Python tooling and test artifacts
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Jupyter
.ipynb_checkpoints/

# Environment files
.env
.env.*
!.env.example
!.env.*.example

# Frontend dependencies and build output
node_modules/
dist/
dist-ssr/

# Runtime/generated uploads
backend/uploads/incoming/*
backend/uploads/processed/*
backend/uploads/failed/*
!backend/uploads/incoming/.gitkeep
!backend/uploads/processed/.gitkeep
!backend/uploads/failed/.gitkeep

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# IDE and OS files
.vscode/
.idea/
*.suo
*.swp
*.swo
.DS_Store
Thumbs.db
